---
import Layout from '../layouts/Layout.astro';
import SectionDivider from '../components/SectionDivider.astro';
import EventCards from '../components/EventCards.astro';
import Icon from '../components/Icon.astro';
---

<Layout 
  title="Gatherings | The Parlour — The World's Most Exclusive Society of Magic"
  description="Private gatherings of The Parlour — the world's most exclusive magic society. Monthly sessions featuring master performances, lectures, and intimate workshops in the conjuring arts."
  keywords="magic meetings, magic gatherings, magic workshops, magician meetups, private magic events, magic performances"
  ogUrl="https://theparlour.com/meetings"
>
    <!-- Hero Section -->
    <section class="hero-section content-hero content-hero-meetings">
        <div class="content-container">
            <h1>Gatherings</h1>
            <p class="lead">Where masters convene and the art comes alive</p>
        </div>
    </section>

    <!-- Upcoming Meetings -->
    <section class="content-listing">
        <div class="content-container">
            <EventCards />
        </div>
    </section>

    <!-- Meeting Information -->
    <section class="content-info">
        <div class="content-container">
            <h2>Our Private Gatherings</h2>
            <div class="content-row">
                <div class="content-col content-col-half">
                    <div class="content-details-card">
                        <h3>When We Convene</h3>
                        <p><strong>Monthly:</strong> Second Monday of each month</p>
                        <p><strong>Time:</strong> 7:00 PM — 9:00 PM</p>
                        <p><strong>Doors:</strong> Open at 6:30 PM for members</p>
                        <p><em>Special events, master classes, and visiting performers are announced exclusively to members via private dispatch.</em></p>
                    </div>
                </div>
                <div class="content-col content-col-half">
                    <div class="content-details-card">
                        <h3>Our Location</h3>
                        <p><strong>Venue:</strong> Private gathering space in Old Town, San Diego</p>
                        <p><strong>Address:</strong> Disclosed to members and invited guests only</p>
                        <p><em>Directions are provided upon confirmation of attendance.</em></p>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <!-- Attending Section -->
    <section class="attending-info">
        <div class="content-container">
          <h2>Attending a Gathering</h2>
            <div class="content-row content-align-center">
                <div class="content-col content-col-half">
                    <div class="attendance-info">
                        <div class="members">
                            <h3>For Members</h3>
                            <p>Members are welcome at all regular gatherings. Simply arrive and present yourself at the door.</p>
                            <p>Select events — such as visiting master lectures and private galas — may require separate registration.</p>
                        </div>
                    </div>
                </div>
                <div class="content-col content-col-half">
                  <div class="attendance-info">
                    <div>
                        <h3>For Invited Guests</h3>
                        <p>Attendance by non-members is by invitation only. Prospective members who have been approved by the Council may attend a single gathering as our guest.</p>
                        <p>If you have received an invitation, please arrive 15 minutes early.</p>
                        <a href="/contact" class="content-btn content-mt-medium">Request an Invitation</a>
                    </div>
                  </div>
                </div>
            </div>
        </div>
    </section>

    <!-- What to Expect -->
    <section class="what-to-expect">
        <div class="content-container">
            <h2>What Awaits Within</h2>
            <div class="content-row">
                <div class="content-col content-col-two-thirds content-offset-col">
                    <div class="expectation-list">
                        <div class="expectation-item">
                            <span class="emoji-icon"><Icon name="masks" /></span>
                            <div>
                                <h4>Master Performances</h4>
                                <p>Members present their finest work — polished routines, new creations, and demonstrations of mastery in an environment of discerning appreciation</p>
                            </div>
                        </div>
                        <div class="expectation-item">
                            <span class="emoji-icon"><Icon name="teacher" /></span>
                            <div>
                                <h4>Lectures &amp; Master Classes</h4>
                                <p>Learn from accomplished professionals and visiting masters who share techniques, theory, and the deeper philosophy of the conjuring arts</p>
                            </div>
                        </div>
                        <div class="expectation-item">
                            <span class="emoji-icon"><Icon name="people" /></span>
                            <div>
                                <h4>The Inner Circle</h4>
                                <p>Connect with fellow practitioners in an atmosphere of mutual respect, shared passion, and the camaraderie of a true secret society</p>
                            </div>
                        </div>
                        <div class="expectation-item">
                            <span class="emoji-icon"><Icon name="books" /></span>
                            <div>
                                <h4>The Vault Access</h4>
                                <p>Browse and check out items from our extraordinary private library of magical literature, rare manuscripts, and archival recordings</p>
                            </div>
                        </div>
                        <div class="expectation-item">
                            <span class="emoji-icon"><Icon name="refresh" /></span>
                            <div>
                                <h4>The Exchange</h4>
                                <p>Members may trade, acquire, or offer rare magical apparatus, literature, and ephemera among fellow collectors and practitioners</p>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <SectionDivider type="wave" />
</Layout>
