---
interface Props {
  title: string;
  description?: string;
  keywords?: string;
  ogTitle?: string;
  ogDescription?: string;
  ogUrl?: string;
}

const { 
  title, 
  description = "The Parlour is the world's most exclusive, invitation-only society of master magicians. An elite private magic club dedicated to the highest echelons of sleight of hand, conjury, and the performing arts of illusion.",
  keywords = "San Diego magic club, San Diego magicians, exclusive magic society, private magic club San Diego, magic show San Diego, sleight of hand, conjuring, magician San Diego, magic performances, elite magic club",
  ogTitle,
  ogDescription,
  ogUrl = "https://theparlour.com"
} = Astro.props;

const currentYear = new Date().getFullYear();
---

<!DOCTYPE html>
<html lang="en">
<head>
    <!-- Prevent white flash before external CSS loads -->
    <style>html { background: #0a0a0a; }</style>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>{title}</title>
    <meta name="description" content={description}>
    <meta name="keywords" content={keywords}>
    <meta name="author" content="The Parlour — The World's Most Exclusive Society of Magic">
    <meta property="og:title" content={ogTitle || title}>
    <meta property="og:description" content={ogDescription || description}>
    <meta property="og:type" content="website">
    <meta property="og:url" content={ogUrl}>

    <!--
      Website designed and built by Misha Osinovskiy.
      Find me on LinkedIn: https://www.linkedin.com/in/mishaosinovskiy/
      If you'd like a website like this, please contact me - I would love to work with you.
    -->

    <link rel="icon" href="/image/favicon.png" type="image/x-icon">
    <link rel="shortcut icon" href="/image/favicon.png" type="image/x-icon">

    <!-- Google Fonts Import — Antique Serif Display + Elegant Old-Style -->
    <link href="https://fonts.googleapis.com/css2?family=Cinzel:wght@400;500;600;700&family=Cormorant+Garamond:ital,wght@0,300;0,400;0,500;0,600;0,700;1,300;1,400;1,500;1,600&family=EB+Garamond:ital,wght@0,400;0,500;0,600;0,700;1,400;1,500&display=swap" rel="stylesheet">

    <!-- Page transition: hide content immediately if arriving from a transition -->
    <script>
      (function(){
        if(sessionStorage.getItem('parlour-transition')){
          var s=document.createElement('style');
          s.id='parlour-transition-init';
          s.textContent='html,body{background:#0a0a0a!important;}#magic-transition-overlay{opacity:1!important;pointer-events:auto!important;}body>*:not(#magic-transition-overlay){opacity:0;}';  
          document.head.appendChild(s);
        }
      })();
    </script>

    <!-- Stylesheets -->
    <link rel="stylesheet" href="/styles/tokens.css">
    <link rel="stylesheet" href="/styles/styles.css">
    <link rel="stylesheet" href="/styles/responsive.css">
    <link rel="stylesheet" href="/styles/content-styles.css">
    <link rel="stylesheet" href="/styles/transitions.css">
    <link rel="stylesheet" href="/styles/dynamic-styles.css">
</head>
<body>
    <header class="main-header">
        <div class="header-container">
            <div class="magic-eyes">
                <div class="eye left">
                    <div class="iris"></div>
                    <div class="pupil"></div>
                </div>
                <div class="eye right">
                    <div class="iris"></div>
                    <div class="pupil"></div>
                </div>
            </div>

            <div class="logo">
              <a href="/">
                <h1>The Parlour</h1>
                <p class="tagline">The World's Most Exclusive Society of Magic</p>
              </a>
            </div>
            
            <div class="hamburger-menu">
                <span></span>
                <span></span>
                <span></span>
            </div>
            
            <nav class="main-nav">
                <div class="nav-inner">
                    <ul>
                        <li><a href="/">Home</a></li>
                        <li><a href="/about">The Society</a></li>
                        <li><a href="/meetings">Gatherings</a></li>
                        <li><a href="/membership">Membership</a></li>
                        <li><a href="/contact" class="btn nav-btn">Request an Invitation</a></li>
                    </ul>
                </div>
            </nav>
            <div class="jumbo-nav">
                <div class="nav-inner">
                    <div class="nav-column">
                        <h3>The Inner Circle</h3>
                        <ul>
                            <li><a href="/">Home</a></li>
                            <li><a href="/about">The Society</a></li>
                            <li><a href="/meetings">Gatherings &amp; Events</a></li>
                            <li><a href="/membership">Membership</a></li>
                            <li><a href="/contact">Request an Invitation</a></li>
                        </ul>
                    </div>
                    
                    <div class="nav-column">
                        <h3>The Archives</h3>
                        <ul>
                            <li><a href="/board">The Council</a></li>
                            <li><a href="/hall-of-fame">Hall of Masters</a></li>
                            <li><a href="/newsletter">Dispatches</a></li>
                            <li><a href="/donate">Patronage</a></li>
                        </ul>
                    </div>
                        
                    <div class="nav-column">
                        <h3>The Séance Room</h3>
                        <ul>
                            <li><a href="/links">Curated Resources</a></li>
                            <li><a href="#" class="do-magic" id="flip-trick">Conjure a Miracle</a></li>
                            <li><span class="tell-secret" id="secret-trick">Reveal the Method</span></li>
                        </ul>
                    </div>
                </div>
            </div>
        </div>
        <div class="header-divider"></div>
    </header>
    <div class="magic-transition-overlay" id="magic-transition-overlay"></div>

    <main>
        <slot />
    </main>

    <footer>
        <div class="container">
            <div class="footer-content">
                <div class="footer-sections">
                    <div class="footer-info">
                        <h3>The Parlour</h3>
                        <p>The World's Most Exclusive Society of Magic</p>
                        <p>Based in San Diego</p>
                        <p class="footer-motto"><em>"Where the impossible becomes art."</em></p>
                    </div>
                    
                    <div class="footer-nav-section">
                        <h3>The Inner Circle</h3>
                        <ul>
                            <li><a href="/">Home</a></li>
                            <li><a href="/about">The Society</a></li>
                            <li><a href="/meetings">Gatherings &amp; Events</a></li>
                            <li><a href="/membership">Membership</a></li>
                            <li><a href="/contact">Request an Invitation</a></li>
                        </ul>
                    </div>
                    
                    <div class="footer-nav-section">
                        <h3>The Archives</h3>
                        <ul>
                            <li><a href="/board">The Council</a></li>
                            <li><a href="/hall-of-fame">Hall of Masters</a></li>
                            <li><a href="/newsletter">Dispatches</a></li>
                            <li><a href="/donate">Patronage</a></li>
                        </ul>
                    </div>
                        
                    <div class="footer-nav-section">
                        <h3>The Séance Room</h3>
                        <ul>
                            <li><a href="/links">Curated Resources</a></li>
                            <li><a href="#" class="do-magic" id="flip-trick-footer">Conjure a Miracle</a></li>
                            <li><span class="tell-secret" id="secret-trick-footer">Reveal the Method</span></li>
                        </ul>
                    </div>
                </div>
            </div>
            <div class="footer-bottom">
                <p>&copy; Beyond Time — The Parlour — The World's Most Exclusive Society of Magic. Based in San Diego. All rights reserved.</p>
                <div class="back-to-top"><br>
                    <a href="#" id="back-to-top-btn">↑ Ascend</a>
                </div>
            </div>
        </div>
    </footer>

    <!-- jQuery -->
    <script is:inline src="https://code.jquery.com/jquery-3.7.1.min.js" integrity="sha256-/JqT3SQfawRcv/BIHPThkBvs0OEvtFFmqPF/lYI/Cxo=" crossorigin="anonymous"></script>
    <!-- Overlay System (must load before navigation) -->
    <script is:inline src="/js/overlay.js"></script>
    <!-- Individual Module JS Files -->
    <script is:inline src="/js/navigation.js"></script>
    <script is:inline src="/js/interactions.js"></script>
    <script is:inline src="/js/animations.js"></script>
    <script is:inline src="/js/forms.js"></script>
    <script is:inline src="/js/chatbot.js"></script>
    <script is:inline src="/js/magicTricks.js"></script>
    <!-- Particles.js -->
    <script is:inline src="/js/particles.js"></script>
    <script is:inline src="/js/particleManager.js"></script>
    <script is:inline src="/js/heroSparkles.js"></script>
    <!-- Links Module -->
    <script is:inline src="/js/links.js"></script>
    <!-- Main Coordinator JS -->
    <script is:inline src="/js/main.js"></script>
    <script is:inline src="/js/transitions.js"></script>
</body>
</html>
