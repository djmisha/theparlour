---
import Layout from '../layouts/Layout.astro';
---

<Layout 
  title="Page Not Found | The Parlour — The World's Most Exclusive Society of Magic"
  description="The page you're looking for seems to have vanished. Let us help you find your way back to the magic."
  ogUrl="https://theparlour.com/404"
  noindex={true}
>
    <section class="hero-section content-hero">
        <div class="content-container">
            <h1>Page Not Found</h1>
            <p class="lead">This page has vanished into thin air!</p>
            <p>The page you're looking for doesn't exist or has been moved.</p>
            <a href="/" class="content-btn content-mt-medium">Return Home</a>
        </div>
    </section>
</Layout>
