---
interface Props {
  title: string;
  description?: string;
  keywords?: string;
  ogTitle?: string;
  ogDescription?: string;
  ogUrl?: string;
  ogImage?: string;
  noindex?: boolean;
  structuredData?: object | object[];
}

const SITE_URL = "https://www.parloursociety.org";
const DEFAULT_OG_IMAGE = `${SITE_URL}/image/hero-home.jpg`;

const { 
  title, 
  description = "The Parlour is the world's most exclusive, invitation-only society of master magicians. An elite private magic club dedicated to the highest echelons of sleight of hand, conjury, and the performing arts of illusion.",
  keywords = "San Diego magic club, San Diego magicians, exclusive magic society, private magic club San Diego, magic show San Diego, sleight of hand, conjuring, magician San Diego, magic performances, elite magic club",
  ogTitle,
  ogDescription,
  ogUrl = SITE_URL,
  ogImage = DEFAULT_OG_IMAGE,
  noindex = false,
  structuredData,
} = Astro.props;

const currentYear = new Date().getFullYear();

const resolvedOgTitle = ogTitle || title;
const resolvedOgDescription = ogDescription || description;

// Base Organization structured data included on every page
const organizationSchema = {
  "@context": "https://schema.org",
  "@type": ["Organization", "SportsOrganization"],
  "@id": `${SITE_URL}/#organization`,
  "name": "The Parlour",
  "alternateName": "The Parlour — The World's Most Exclusive Society of Magic",
  "url": SITE_URL,
  "logo": {
    "@type": "ImageObject",
    "url": `${SITE_URL}/image/favicon.svg`
  },
  "image": DEFAULT_OG_IMAGE,
  "description": "The Parlour is the world's most exclusive, invitation-only society of master magicians based in San Diego, California.",
  "foundingLocation": {
    "@type": "Place",
    "name": "San Diego, California, United States"
  },
  "areaServed": {
    "@type": "City",
    "name": "San Diego"
  },
  "sameAs": [
    SITE_URL
  ]
};

const webSiteSchema = {
  "@context": "https://schema.org",
  "@type": "WebSite",
  "@id": `${SITE_URL}/#website`,
  "url": SITE_URL,
  "name": "The Parlour",
  "description": "The World's Most Exclusive Society of Magic",
  "publisher": {
    "@id": `${SITE_URL}/#organization`
  },
  "potentialAction": {
    "@type": "SearchAction",
    "target": {
      "@type": "EntryPoint",
      "urlTemplate": `${SITE_URL}/resources?q={search_term_string}`
    },
    "query-input": "required name=search_term_string"
  }
};

const allStructuredData = [
  organizationSchema,
  webSiteSchema,
  ...(structuredData ? (Array.isArray(structuredData) ? structuredData : [structuredData]) : [])
];
---

<!DOCTYPE html>
<html lang="en">
<head>
    <!-- Prevent white flash before external CSS loads -->
    <style>html { background: #0a0a0a; }</style>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>{title}</title>
    <meta name="description" content={description}>
    <meta name="keywords" content={keywords}>
    <meta name="author" content="The Parlour — The World's Most Exclusive Society of Magic">
    {noindex && <meta name="robots" content="noindex, nofollow">}
    {!noindex && <meta name="robots" content="index, follow, max-snippet:-1, max-image-preview:large, max-video-preview:-1">}
    <meta name="theme-color" content="#c9a959">

    <!-- Canonical URL -->
    <link rel="canonical" href={ogUrl}>

    <!-- Open Graph -->
    <meta property="og:title" content={resolvedOgTitle}>
    <meta property="og:description" content={resolvedOgDescription}>
    <meta property="og:type" content="website">
    <meta property="og:url" content={ogUrl}>
    <meta property="og:image" content={ogImage}>
    <meta property="og:image:width" content="1200">
    <meta property="og:image:height" content="630">
    <meta property="og:image:alt" content={resolvedOgTitle}>
    <meta property="og:site_name" content="The Parlour">
    <meta property="og:locale" content="en_US">

    <!-- Twitter / X Card -->
    <meta name="twitter:card" content="summary_large_image">
    <meta name="twitter:title" content={resolvedOgTitle}>
    <meta name="twitter:description" content={resolvedOgDescription}>
    <meta name="twitter:image" content={ogImage}>
    <meta name="twitter:image:alt" content={resolvedOgTitle}>

    <!-- Structured Data (JSON-LD) -->
    <script type="application/ld+json" set:html={JSON.stringify(allStructuredData)} />

    <!-- Favicon & Web Manifest -->
    <link rel="icon" href="/image/favicon.svg" type="image/svg+xml">
    <link rel="shortcut icon" href="/image/favicon.svg" type="image/svg+xml">
    <link rel="apple-touch-icon" href="/image/favicon.svg">
    <link rel="manifest" href="/site.webmanifest">

    <!-- Preconnect for performance -->
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>

    <!-- Google Fonts Import — Antique Serif Display + Elegant Old-Style -->
    <link href="https://fonts.googleapis.com/css2?family=Cinzel:wght@400;500;600;700&family=Cormorant+Garamond:ital,wght@0,300;0,400;0,500;0,600;0,700;1,300;1,400;1,500;1,600&family=EB+Garamond:ital,wght@0,400;0,500;0,600;0,700;1,400;1,500&display=swap" rel="stylesheet">

    <!-- Page transition: hide content immediately if arriving from a transition -->
    <script>
      (function(){
        if(sessionStorage.getItem('parlour-transition')){
          var s=document.createElement('style');
          s.id='parlour-transition-init';
          s.textContent='html,body{background:#0a0a0a!important;}#magic-transition-overlay{opacity:1!important;pointer-events:auto!important;}body>*:not(#magic-transition-overlay){opacity:0;}';  
          document.head.appendChild(s);
        }
      })();
    </script>

    <!-- Stylesheets -->
    <link rel="stylesheet" href="/styles/tokens.css">
    <link rel="stylesheet" href="/styles/styles.css">
    <link rel="stylesheet" href="/styles/responsive.css">
    <link rel="stylesheet" href="/styles/content-styles.css">
    <link rel="stylesheet" href="/styles/transitions.css">
    <link rel="stylesheet" href="/styles/dynamic-styles.css">
</head>
<body>
    <header class="main-header">
        <div class="header-container">
            <div class="magic-eyes">
                <div class="eye left">
                    <div class="iris"></div>
                    <div class="pupil"></div>
                </div>
                <div class="eye right">
                    <div class="iris"></div>
                    <div class="pupil"></div>
                </div>
            </div>

            <div class="logo">
              <a href="/">
                <h1>The Parlour</h1>
                <p class="tagline">The World's Most Exclusive Society of Magic</p>
              </a>
            </div>
            
            <nav class="main-nav">
                <div class="nav-inner">
                    <ul>
                        <li><a href="/">Home</a></li>
                        <li><a href="/the-society">The Society</a></li>
                        <li><a href="/membership">Membership</a></li>
                        <li><a href="/resources">The Collection</a></li>
                    </ul>
                </div>
            </nav>

            <div class="hamburger-menu">
                <span></span>
                <span></span>
                <span></span>
            </div>
            <div class="jumbo-nav">
                <div class="nav-inner">
                    <div class="nav-column">
                        <h3>The Inner Circle</h3>
                        <ul>
                            <li><a href="/">Home</a></li>
                            <li><a href="/the-society">The Society</a></li>
                            <li><a href="/membership">Membership</a></li>
                            <li><a href="/gatherings">Gatherings</a></li>
                            <li><a href="/learn">The Conservatory</a></li>
                        </ul>
                    </div>
                    
                    <div class="nav-column">
                        <h3>The Chamber</h3>
                        <ul>
                            <li><a href="/the-council">The Council</a></li>
                            <li><a href="/hall-of-masters">Hall of Masters</a></li>
                            <li><a href="/patronage">Patronage</a></li>
                            <li><a href="#" class="open-contact-form">Request an Invitation</a></li>
                        </ul>
                    </div>
                        
                    <div class="nav-column">
                        <h3>The Séance Room</h3>
                        <ul>
                            <li><a href="/resources">The Collection</a></li>
                            <li><a href="#" class="do-magic" id="flip-trick">Conjure a Miracle</a></li>
                            <li><span class="tell-secret" id="secret-trick">Reveal the Method</span></li>
                        </ul>
                    </div>
                </div>
            </div>
        </div>
        <div class="header-divider"></div>
    </header>
    <div class="magic-transition-overlay" id="magic-transition-overlay"></div>

    <!-- Hidden form for Netlify form detection (JS-rendered forms need a static counterpart) -->
    <form name="contact" method="POST" data-netlify="true" data-netlify-honeypot="bot-field" style="display:none">
        <input type="text" name="name" />
        <input type="email" name="email" />
        <input type="tel" name="phone" />
        <input type="text" name="experience" />
        <input type="text" name="specialization" />
        <input type="text" name="referral" />
        <textarea name="message"></textarea>
        <input type="text" name="bot-field" />
    </form>

    <!-- Hidden form for Netlify enrollment form detection -->
    <form name="enrollment" method="POST" data-netlify="true" data-netlify-honeypot="bot-field" style="display:none">
        <input type="text" name="name" />
        <input type="email" name="email" />
        <input type="tel" name="phone" />
        <input type="text" name="bot-field" />
    </form>

    <main>
        <slot />
    </main>

    <footer>
        <div class="footer-nav-grid">
            <div class="footer-col">
                <h3>The Inner Circle</h3>
                <ul>
                    <li><a href="/">Home</a></li>
                    <li><a href="/the-society">The Society</a></li>
                    <li><a href="/membership">Membership</a></li>
                    <li><a href="/gatherings">Gatherings</a></li>
                    <li><a href="/learn">The Conservatory</a></li>
                </ul>
            </div>
            <div class="footer-col">
                <h3>The Chamber</h3>
                <ul>
                    <li><a href="/the-council">The Council</a></li>
                    <li><a href="/hall-of-masters">Hall of Masters</a></li>
                    <li><a href="/patronage">Patronage</a></li>
                    <li><a href="#" class="open-contact-form">Request an Invitation</a></li>
                </ul>
            </div>
            <div class="footer-col">
                <h3>The Séance Room</h3>
                <ul>
                    <li><a href="/resources">The Collection</a></li>
                    <li><a href="#" class="do-magic" id="flip-trick-footer">Conjure a Miracle</a></li>
                    <li><span class="tell-secret" id="secret-trick-footer">Reveal the Method</span></li>
                </ul>
            </div>
        </div>
        <div class="footer-identity">
            <div class="footer-identity-top">
                <h2 class="footer-logo-name">The Parlour</h2>
                <p class="footer-logo-tagline">The World's Most Exclusive Society of Magic &bull; San Diego</p>
            </div>
            <div class="footer-identity-bottom">
                <p class="footer-copyright">&copy; Beyond Time — The Parlour. All rights reserved.</p>
                <a href="#" id="back-to-top-btn" class="footer-ascend">↑ Ascend</a>
            </div>
        </div>
    </footer>

    <!-- jQuery -->
    <script is:inline src="https://code.jquery.com/jquery-3.7.1.min.js" integrity="sha256-/JqT3SQfawRcv/BIHPThkBvs0OEvtFFmqPF/lYI/Cxo=" crossorigin="anonymous"></script>
    <!-- Overlay System (must load before navigation) -->
    <script is:inline src="/js/overlay.js"></script>
    <!-- Individual Module JS Files -->
    <script is:inline src="/js/navigation.js"></script>
    <script is:inline src="/js/interactions.js"></script>
    <script is:inline src="/js/animations.js"></script>
    <script is:inline src="/js/forms.js"></script>
    <script is:inline src="/js/chatbot.js"></script>
    <script is:inline src="/js/magicTricks.js"></script>
    <!-- Particles.js -->
    <script is:inline src="/js/particles.js"></script>
    <script is:inline src="/js/particleManager.js"></script>
    <script is:inline src="/js/heroSparkles.js"></script>
    <!-- Links Module -->
    <script is:inline src="/js/links.js"></script>
    <!-- Main Coordinator JS -->
    <script is:inline src="/js/main.js"></script>
    <script is:inline src="/js/transitions.js"></script>
</body>
</html>
