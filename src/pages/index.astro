---
import Layout from '../layouts/Layout.astro';
import SectionDivider from '../components/SectionDivider.astro';
import EventCards from '../components/EventCards.astro';
import ContactForm from '../components/ContactForm.astro';
---

<Layout 
  title="The Parlour — San Diego's Most Exclusive Magic Society | Private Magic Club"
  description="The Parlour is San Diego's most exclusive, invitation-only society of master magicians. An elite private magic club dedicated to the highest echelons of sleight of hand, conjury, and the performing arts of illusion."
  keywords="San Diego magic club, San Diego magicians, exclusive magic society, private magic club San Diego, magic show San Diego, sleight of hand, conjuring, magician San Diego, magic performances, elite magic club"
  ogUrl="https://ring76.com"
>
    <section id="hero" class="hero-section hero-home">
        <div class="hero-content">
            <h1>Where the Impossible Becomes Art</h1>
            <p>San Diego's most exclusive society of conjurers, illusionists, and master magicians</p>
            <a href="#membership" class="btn">Request an Invitation</a>
        </div>
    </section>

    <section id="about" class="about-section">
        <div class="container">
            <h2>A Society Unlike Any Other</h2>
            <p>The Parlour is an invitation-only collective of San Diego's most accomplished magicians — a private society where the ancient art of conjury is practiced, preserved, and perfected behind closed doors. We do not advertise. We do not recruit. Those who belong, know. Those who seek to join must prove they are worthy of the secrets within.</p>
        </div>
    </section>

    <SectionDivider type="wave" />

    <EventCards />

    <SectionDivider type="peaks" />

    <section id="magic-arts" class="magic-arts-section">
        <div class="container">
            <h2>The Disciplines We Master</h2>
            <p class="section-intro">Each member of The Parlour dedicates themselves to one or more of the classical magical arts — disciplines that demand years of devoted practice and an unwavering commitment to excellence.</p>
            
            <div class="art-forms-container">
                <div class="art-form">
                    <div class="art-icon">👐</div>
                    <h3>Sleight of Hand</h3>
                    <p>The purest form of magic — where bare hands create impossible realities through years of disciplined practice, misdirection, and flawless technique.</p>
                </div>
                <div class="art-form">
                    <div class="art-icon">♠️</div>
                    <h3>Card Conjury</h3>
                    <p>The aristocrat's art. From elegant card manipulations to mind-bending predictions, our members command the 52 pasteboards with surgical precision.</p>
                </div>
                <div class="art-form">
                    <div class="art-icon">💰</div>
                    <h3>Coin & Close-Up</h3>
                    <p>Intimate miracles performed inches from the spectator's eyes — vanishes, transpositions, and transformations that defy every sense.</p>
                </div>
                <div class="art-form">
                    <div class="art-icon">🎭</div>
                    <h3>Grand Illusion</h3>
                    <p>The theatre of the impossible. Large-scale illusions that combine engineering, artistry, and stagecraft into breathtaking spectacles of wonder.</p>
                </div>
                <div class="art-form">
                    <div class="art-icon">🧠</div>
                    <h3>Mentalism</h3>
                    <p>The art of apparent mind-reading, psychological influence, and impossible predictions — where the magician's greatest prop is the human mind itself.</p>
                </div>
                <div class="art-form">
                    <div class="art-icon">✨</div>
                    <h3>Presentation & Performance</h3>
                    <p>The craft that elevates tricks into art. Scripting, staging, audience psychology, and the theatrical command that separates amateurs from masters.</p>
                </div>
            </div>
            
            <div class="magic-arts-cta">
                <a href="#contact" class="btn btn-gold">Begin Your Journey</a>
            </div>
        </div>
    </section>

    <SectionDivider type="curve" />

    <section id="experience-magic" class="experience-magic-section">
        <div class="container">
            <h2>The Parlour Experience</h2>
            <p class="section-intro">What awaits behind the doors of San Diego's most private magic society</p>
            
            <div class="magic-experience-content">
                <div class="magic-experience-text">
                    <p>Magic, at its highest level, is not entertainment — it is art. It is the ability to shatter a person's understanding of reality, if only for a moment, and replace it with pure wonder. At The Parlour, we believe this art form deserves the same reverence as any other fine art — practiced in private, presented with elegance, and shared only among those who truly understand its power.</p>
                    <p>Our members are not hobbyists. They are dedicated practitioners — professionals, scholars, and devotees of the craft who have spent years mastering the invisible techniques that make the impossible appear effortless. Here, you will find no casual dabblers. Only those who treat magic as a lifelong pursuit.</p>
                    
                    <div class="magic-benefit-cards">
                        <div class="magic-benefit-card">
                            <span class="benefit-icon">✨</span>
                            <h3>Mastery of Craft</h3>
                            <p>Study under San Diego's most accomplished conjurers in private sessions</p>
                        </div>
                        <div class="magic-benefit-card">
                            <span class="benefit-icon">🔮</span>
                            <h3>Forbidden Knowledge</h3>
                            <p>Access one of the largest private magic libraries in the Western United States</p>
                        </div>
                        <div class="magic-benefit-card">
                            <span class="benefit-icon">🎭</span>
                            <h3>Command the Room</h3>
                            <p>Perfect your performance in an environment of uncompromising excellence</p>
                        </div>
                        <div class="magic-benefit-card">
                            <span class="benefit-icon">🌟</span>
                            <h3>The Inner Circle</h3>
                            <p>Join a private network of San Diego's most elite magical artists</p>
                        </div>
                    </div>
                    
                    <div class="cta-container">
                        <a href="#contact" class="btn">Seek Admission</a>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <SectionDivider type="zigzag" />

    <section id="membership" class="membership-section">
        <div class="container">
            <h2>Membership Is a Privilege</h2>
            <p>The Parlour does not accept everyone. Admission is by invitation or petition only, reviewed by our Council, and granted to those who demonstrate exceptional skill, genuine dedication to the craft, and the character befitting our society. Membership is a commitment — to excellence, to secrecy, and to the elevation of magic as an art form.</p>
            
            <div class="benefits-container">
                <div class="benefit">
                    <h3>Private Gatherings</h3>
                    <p>Attend exclusive monthly sessions featuring master-class performances, lectures by world-renowned conjurers, and intimate workshops in the classical arts of magic.</p>
                </div>
                <div class="benefit">
                    <h3>The Vault</h3>
                    <p>Access our private library — one of the most comprehensive collections of magical literature, rare manuscripts, and instructional archives in the country.</p>
                </div>
                <div class="benefit">
                    <h3>Master Mentorship</h3>
                    <p>Study directly under accomplished professionals who have performed on the world's most prestigious stages and dedicated decades to the craft.</p>
                </div>
                <div class="benefit">
                    <h3>Performance Stage</h3>
                    <p>Present your art in an environment of uncompromising standards, where your work is met with the discerning appreciation it deserves.</p>
                </div>
                <div class="benefit">
                    <h3>Private Network</h3>
                    <p>Connect with an elite collective of San Diego's finest magicians — a confidential network of professionals, scholars, and master practitioners.</p>
                </div>
                <div class="benefit">
                    <h3>Leadership Opportunities</h3>
                    <p>Shape the future of San Diego's magical arts by serving on our Council and guiding the direction of the society.</p>
                </div>
            </div>
            
            <div class="membership-cta">
                <a href="#contact" class="btn">Petition for Membership</a>
            </div>
        </div>
    </section>

    <SectionDivider type="peaks" />

    <section id="library" class="library-section">
        <div class="container">
            <h2>The Vault</h2>
            <p class="library-tagline">One of the most extraordinary private collections of magical knowledge in the Western United States — accessible only to members of The Parlour.</p>
            
            <div class="library-content">
                <div class="library-info">
                    <div class="library-stat">
                        <span class="stat-number">Centuries of</span>
                        <span class="stat-label">Rare Magical Literature</span>
                    </div>
                    <div class="library-stat">
                        <span class="stat-number">Thousands of</span>
                        <span class="stat-label">Performance Techniques</span>
                    </div>
                    <div class="library-stat">
                        <span class="stat-number">Exclusive</span>
                        <span class="stat-label">Archival Manuscripts &amp; Film</span>
                    </div>
                    <a href="#contact" class="btn btn-outline">Request Access</a>
                </div>
            </div>
        </div>
    </section>

    <SectionDivider type="curve" />

    <ContactForm />

    <SectionDivider type="wave" />
</Layout>
