---
import Layout from '../layouts/Layout.astro';
import SectionDivider from '../components/SectionDivider.astro';
import BoardMembers from '../components/BoardMembers.astro';
---

<Layout 
  title="The Council | The Parlour — The World's Most Exclusive Society of Magic"
  description="Meet The Council — the distinguished leaders who guide The Parlour, San Diego's most exclusive private magic society. Stewards of tradition and excellence."
  keywords="San Diego magic, San Diego magicians, exclusive magic club, private magic society, magic show San Diego, magic council, magic leadership"
  ogUrl="https://theparlour.com/board"
>
    <!-- Hero Section -->
    <section class="hero-section content-hero content-hero-board">
        <div class="content-container">
            <h1>The Council</h1>
            <p class="lead">The guardians of our tradition</p>
        </div>
    </section>

    <!-- Introduction Section -->
    <section class="content-info">
        <div class="content-container">
            <h2>Our Leadership</h2>
            <div class="content-row">
                <div class="content-col content-col-full">
                    <div class="content-details-card">
                        <h3>Stewards of the Art</h3>
                        <p>The Council is the governing body of The Parlour, entrusted with safeguarding the society's vision, legacy, and standards of excellence. Composed of distinguished members who have demonstrated unwavering dedication to the craft, each Council member upholds the traditions that define our institution.</p>
                        <p>Together, they curate the experiences, set the standards, and ensure that The Parlour remains San Diego's most prestigious sanctuary for the magical arts.</p>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <!-- Officer Bios Section -->
    <section class="content-info">
        <div class="content-container">
            <h2>Meet The Current Council</h2>
            <BoardMembers />
        </div>
    </section>

    <!-- Board Responsibilities Section -->
    <section class="location-details">
        <div class="content-container">
            <div class="content-row">
                <div class="content-col content-col-full">
                    <h2>Council Responsibilities</h2>
                    <div class="content-row">
                        <div class="content-col">
                            <div class="expectation-item">
                                <span class="emoji-icon">📋</span>
                                <div>
                                    <h4>Society Governance</h4>
                                    <p>The Council oversees all facets of The Parlour's operations, from strategic direction and financial stewardship to upholding the standards that define our institution. They ensure the society remains true to its mission of preserving and advancing the magical arts.</p>
                                </div>
                            </div>
                        </div>
                        <div class="content-col content-col-half content-mt-medium">
                            <div class="expectation-item">
                                <span class="emoji-icon">🎭</span>
                                <div>
                                    <h4>Curated Experiences</h4>
                                    <p>From exclusive gatherings and masterclasses to private performances, The Council curates every event with meticulous attention. They secure world-class guest artists, orchestrate competitions, and create unparalleled opportunities for members to refine their craft.</p>
                                </div>
                            </div>
                        </div>
                        <div class="content-col content-col-half content-mt-medium">
                            <div class="expectation-item">
                                <span class="emoji-icon">🤝</span>
                                <div>
                                    <h4>Member Cultivation</h4>
                                    <p>The Council nurtures the growth of every member, pairing emerging practitioners with seasoned mentors and fostering an environment where knowledge is exchanged with generosity and discretion.</p>
                                </div>
                            </div>
                        </div>
                        <div class="content-col content-mt-medium">
                            <div class="expectation-item">
                                <span class="emoji-icon">🌐</span>
                                <div>
                                    <h4>Community Presence</h4>
                                    <p>Representing The Parlour in the broader world, The Council cultivates relationships with distinguished magical organizations, coordinates select public engagements, and elevates the art of magic throughout San Diego.</p>
                                </div>
                            </div>
                        </div>
                        <div class="content-col content-mt-medium">
                            <div class="expectation-item">
                                <span class="emoji-icon">💬</span>
                                <div>
                                    <h4>Contribute</h4>
                                    <p>Members in good standing are welcome to attend Council sessions and offer their perspective — a privilege we hold in high regard. Formal votes are reserved for Council members. We encourage those with vision to seek a seat at the table.</p>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <!-- Elections Section -->
    <section class="what-to-expect">
        <div class="content-container">
            <h2>Annual Succession</h2>
            <div class="content-row">
                <div class="content-col content-col-two-thirds content-offset-col">
                    <div class="expectation-list">
                        <div class="expectation-item">
                            <span class="emoji-icon">🗳️</span>
                            <div>
                                <h4>The Selection</h4>
                                <p>Each year, The Parlour convenes to select the next Council. All members in good standing may cast their vote. Selections are held in June, with the new Council assuming their duties in July.</p>
                            </div>
                        </div>
                        <div class="expectation-item">
                            <span class="emoji-icon">👥</span>
                            <div>
                                <h4>Nomination Period</h4>
                                <p>Members may put forward themselves or distinguished peers for Council positions. Nominations open in April, allowing candidates to articulate their vision for the society's future.</p>
                            </div>
                        </div>
                        <div class="expectation-item">
                            <span class="emoji-icon">⚖️</span>
                            <div>
                                <h4>Term of Service</h4>
                                <p>Council members serve one-year terms with the opportunity for renewal. This ensures a balance of institutional knowledge and fresh vision, keeping the society dynamic and attuned to its members.</p>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <!-- Join the Board Section -->
    <section class="attending-info">
        <div class="content-container">
            <h2>Join The Council</h2>
            <div class="content-row content-align-center">
                <div class="content-col content-col-half">
                    <div class="attendance-info">
                        <div class="members">
                            <h3>The Privileges of Service</h3>
                            <p>Serving on The Council is both an honor and a responsibility — an opportunity to shape the future of San Diego's most distinguished magical institution:</p>
                            <ul>
                                <li>Direct the future of the art in San Diego</li>
                                <li>Forge connections with world-class practitioners</li>
                                <li>Refine your leadership and curatorial instincts</li>
                                <li>Cultivate lasting bonds within an elite community</li>
                                <li>Leave an enduring mark on the magical arts</li>
                            </ul>
                        </div>
                    </div>
                </div>
                <div class="content-col content-col-half">
                    <div class="attendance-info">
                        <div>
                            <h3>Ready to Serve?</h3>
                            <p>The strength of our society rests upon those who are willing to dedicate their time, talent, and vision. By serving on The Council, you help ensure that The Parlour endures as San Diego's premier sanctuary for the magical arts.</p>
                            <p>Express your interest to any current Council member to learn more about available positions and the selection process.</p>
                            <a href="/contact" class="content-btn content-mt-medium">Seek a Position</a>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </section>
   
    <SectionDivider type="wave" />
</Layout>
