---
import Layout from '../layouts/Layout.astro';
import SectionDivider from '../components/SectionDivider.astro';
import linksData from '../data/links.json';

interface Link {
  Name: string;
  Type: string;
  LinkURL: string;
  Description: string;
}

const typeOrder = ['Magician', 'Org', 'Vendor', 'Mfg', 'Resource', 'Other'];

const typeNames: Record<string, string> = {
  'Mfg': 'Manufacturers',
  'Vendor': 'Vendors',
  'Magician': 'Magicians',
  'Resource': 'Resources',
  'Org': 'Organizations',
  'Other': 'Other'
};

const typeIcons: Record<string, string> = {
  'Magician': '✦',
  'Org': '⬡',
  'Vendor': '◈',
  'Mfg': '⬟',
  'Resource': '◉',
  'Other': '◇'
};

const links = linksData as Link[];
const totalCount = links.length;

// Serialize for client-side JS
const linksJSON = JSON.stringify(links);
---

<Layout 
  title="The World's Most Complete Magic Resource Library | The Parlour"
  description="The Parlour presents the world's most comprehensive curated collection of magic resources — magicians, organizations, manufacturers, vendors, and knowledge. Assembled by San Diego's exclusive society of magic."
  keywords="magic resources, magic links, famous magicians, magic organizations, magic shops, magic manufacturers, magic books, San Diego magic, curated magic collection"
  ogUrl="https://theparlour.com/links"
>
    <!-- Hero Section -->
    <section class="hero-section content-hero content-hero-links">
        <div class="content-container">
            <p class="links-hero-eyebrow">The Parlour Presents</p>
            <h1 class="links-page-title">The World's Most Complete Magic Resource Library</h1>
            <p class="lead">Every great magician, shop, organization &amp; resource — curated in one place</p>
            <div class="links-hero-stats">
                <div class="links-stat">
                    <span class="links-stat-number">{totalCount}+</span>
                    <span class="links-stat-label">Curated Resources</span>
                </div>
                <div class="links-stat-divider">✦</div>
                <div class="links-stat">
                    <span class="links-stat-number">6</span>
                    <span class="links-stat-label">Categories</span>
                </div>
                <div class="links-stat-divider">✦</div>
                <div class="links-stat">
                    <span class="links-stat-number">∞</span>
                    <span class="links-stat-label">Years of Magic</span>
                </div>
            </div>
        </div>
    </section>

    <!-- Introduction Section -->
    <section class="content-info links-intro-section">
        <div class="content-container">
            <div class="links-intro-card">
                <div class="links-intro-text">
                    <h2>A Living Library of Magic</h2>
                    <p>The Parlour has assembled the most comprehensive directory of magical resources ever curated online. From the world's greatest performers to rare manufacturers, from landmark organizations to essential learning resources — everything the serious student and seasoned professional needs is here, gathered with the same devotion to excellence that defines our Society.</p>
                    <p>This collection is a living library, grown from decades of magical community knowledge. The Parlour does not endorse specific products or services. If you wish to suggest a worthy addition or report a broken link, please <a href="/contact">contact us</a>.</p>
                </div>
                <div class="links-intro-note">
                    <span class="links-note-icon">✦</span>
                    <p><em>All links open in a new tab. Curated by The Parlour — San Diego's Exclusive Society of Magic.</em></p>
                </div>
            </div>
        </div>
    </section>

    <!-- Search + Filter Controls -->
    <section class="links-controls-section">
        <div class="content-container">
            <!-- Search Bar -->
            <div class="links-search-wrapper">
                <div class="links-search-bar">
                    <span class="links-search-icon">⌕</span>
                    <input 
                        type="text" 
                        id="links-search-input" 
                        placeholder="Search magicians, shops, organizations…" 
                        autocomplete="off"
                        aria-label="Search magic resources"
                    />
                    <button id="links-search-clear" class="links-search-clear" aria-label="Clear search" style="display:none;">✕</button>
                </div>
                <p id="links-result-count" class="links-result-count">{totalCount} resources</p>
            </div>

            <!-- Category Filters -->
            <div class="links-filter-bar" role="tablist" aria-label="Filter by category">
                <button class="links-filter-btn active" data-type="all" role="tab" aria-selected="true">
                    <span class="filter-icon">✦</span> All
                    <span class="filter-count">{totalCount}</span>
                </button>
                {typeOrder.map(type => {
                    const count = links.filter(l => l.Type === type).length;
                    return (
                        <button class="links-filter-btn" data-type={type} role="tab" aria-selected="false">
                            <span class="filter-icon">{typeIcons[type]}</span> {typeNames[type]}
                            <span class="filter-count">{count}</span>
                        </button>
                    );
                })}
            </div>
        </div>
    </section>

    <!-- Links Grid -->
    <section class="links-grid-section">
        <div class="content-container">
            <p id="links-no-results" class="links-no-results" style="display:none;">
                No resources found. Try a different search or category.
            </p>
            <div id="links-grid" class="links-card-grid">
                {links.map(link => (
                    <a 
                        href={link.LinkURL || '#'} 
                        class="link-card"
                        data-name={(link.Name || '').toLowerCase()}
                        data-desc={(link.Description || '').toLowerCase()}
                        data-type={link.Type}
                        target="_blank" 
                        rel="noopener noreferrer"
                    >
                        <div class="link-card-inner">
                            <div class="link-card-header">
                                <span class="link-card-type-badge">{typeNames[link.Type] || link.Type}</span>
                                <span class="link-card-arrow">↗</span>
                            </div>
                            <h3 class="link-card-name">{link.Name}</h3>
                            <p class="link-card-desc">{link.Description}</p>
                            <div class="link-card-footer">
                                <span class="link-card-domain">{link.LinkURL ? link.LinkURL.replace(/^https?:\/\/(www\.)?/, '').split('/')[0] : ''}</span>
                            </div>
                        </div>
                    </a>
                ))}
            </div>
        </div>
    </section>

    <SectionDivider type="wave" />

    <script is:inline define:vars={{ linksJSON }}>
      window.__LINKS_DATA__ = JSON.parse(linksJSON);
    </script>
</Layout>
