---

<svg
  xmlns="http://www.w3.org/2000/svg"
  width={size}
  height={size}
  viewBox="0 0 24 24"
  fill="none"
  class="icon"
  aria-hidden="true"
  set:html={svgContent}
/>

<style>
  .icon {
    color: var(--color-gold, #c9a959);
    flex-shrink: 0;
    display: inline-block;
    vertical-align: middle;
  }
</style>
